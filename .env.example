# =====================================================================
# Avarent Outbound — environment configuration
# Copy to `.env.local`. The app runs fully in DEMO mode with no keys set.
# =====================================================================

# Data mode: "demo" (seeded, in-browser, zero backend) or "live" (Supabase).
NEXT_PUBLIC_DATA_MODE=demo

# --- Supabase (only needed when NEXT_PUBLIC_DATA_MODE=live) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Email sending (only needed for real outbound) ---
# Primary transactional provider.
RESEND_API_KEY=
# Generic SMTP fallback / additional mailboxes.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Background worker ---
# Shared secret required to POST /api/worker/tick (set the same value in your cron job).
WORKER_SECRET=dev-worker-secret

# --- Optional AI (personalization / reply classification only; off by default) ---
AI_ENABLED=false
ANTHROPIC_API_KEY=
